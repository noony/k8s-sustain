{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "imagePullSecrets": { "type": "array" },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "recommendOnly": { "type": "boolean" },
    "prometheusAddress": { "type": "string" },
    "controller": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "metricsBindAddress": { "type": "string" },
        "healthProbeBindAddress": { "type": "string" },
        "leaderElect": { "type": "boolean" },
        "logLevel": { "type": "string", "enum": ["debug", "info", "warn", "error"] },
        "service": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "port": { "type": "integer" }
          }
        },
        "resources": { "type": "object" },
        "serviceMonitor": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "interval": { "type": "string" },
            "scrapeTimeout": { "type": "string" }
          }
        },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" }
      }
    },
    "installCRDs": { "type": "boolean" },
    "webhook": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 1 },
        "port": { "type": "integer" },
        "logLevel": { "type": "string", "enum": ["debug", "info", "warn", "error"] },
        "failurePolicy": { "type": "string", "enum": ["Ignore", "Fail"] },
        "excludedNamespaces": { "type": "array", "items": { "type": "string" } },
        "tlsSecretName": { "type": "string" },
        "caBundle": { "type": "string" },
        "certManager": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "issuerRef": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "kind": { "type": "string" }
              }
            }
          }
        },
        "resources": { "type": "object" },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" }
      }
    },
    "dashboard": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 1 },
        "port": { "type": "integer" },
        "bindAddress": { "type": "string" },
        "logLevel": { "type": "string", "enum": ["debug", "info", "warn", "error"] },
        "service": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "port": { "type": "integer" }
          }
        },
        "resources": { "type": "object" },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" }
      }
    }
  }
}
